@page
@model MyPortal.WebApi.Areas.Account.Pages.LoginModel
@{
    Layout = "/Pages/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Welcome back";
}
<form method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />

    <div class="field">
        <label class="field__label" asp-for="Input.Username">Username</label>
        <input class="field__input" asp-for="Input.Username" autocomplete="username" autofocus placeholder="e.g. j.smith" />
    </div>

    <div class="field">
        <label class="field__label" asp-for="Input.Password">Password</label>
        <input class="field__input" asp-for="Input.Password" type="password" autocomplete="current-password" placeholder="••••••••" />
    </div>

    <div class="form__row">
        <label class="remember">
            <input asp-for="Input.RememberMe" type="checkbox" /> Keep me signed in
        </label>
    </div>

    <button type="submit" class="btn">Sign in</button>

    <span asp-validation-summary="All" class="errors"></span>
</form>
