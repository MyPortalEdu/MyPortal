<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] · MyPortal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --indigo-950: #1e1b4b;
            --indigo-900: #312e81;
            --indigo-700: #4338ca;
            --indigo-600: #4f46e5;
            --indigo-400: #818cf8;
            --indigo-300: #a5b4fc;
            --ink: #0f172a;
            --muted: #64748b;
            --line: #e5e7eb;
            --surface: #ffffff;
            --surface-2: #f8fafc;
            --amber: #f59e0b;
            --emerald: #10b981;
            --violet: #8b5cf6;
            --rose: #f43f5e;
            --focus: #6366f1;
        }

        * { box-sizing: border-box; }

        html, body { height: 100%; }

        body {
            margin: 0;
            font-family: "Inter Variable", "Inter", ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            font-feature-settings: "cv11", "ss01", "ss03";
            color: var(--ink);
            background: var(--surface);
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        .auth {
            display: grid;
            grid-template-columns: 1.05fr 0.95fr;
            min-height: 100%;
        }

        /* ---- Brand panel: the timetable ------------------------------------ */
        .auth__brand {
            position: relative;
            overflow: hidden;
            padding: 3rem;
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            background: radial-gradient(120% 120% at 80% 0%, var(--indigo-700) 0%, var(--indigo-900) 45%, var(--indigo-950) 100%);
            color: #eef2ff;
        }

        .brand__grid {
            position: absolute;
            inset: 2.5rem 2.5rem 52% 2.5rem;
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            grid-auto-rows: 1fr;
            gap: 0.5rem;
            pointer-events: none;
        }

        .cell {
            border: 1px solid rgba(165, 180, 252, 0.16);
            border-radius: 7px;
            background: rgba(129, 140, 248, 0.04);
        }

        .cell--lesson {
            border-color: transparent;
            box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.05);
        }

        .cell--a { background: rgba(245, 158, 11, 0.20); border-left: 3px solid var(--amber); }
        .cell--b { background: rgba(16, 185, 129, 0.20); border-left: 3px solid var(--emerald); }
        .cell--c { background: rgba(139, 92, 246, 0.24); border-left: 3px solid var(--violet); }
        .cell--d { background: rgba(244, 63, 94, 0.20); border-left: 3px solid var(--rose); }

        .brand__content { position: relative; max-width: 26rem; }

        .brand__mark {
            display: inline-flex;
            align-items: center;
            gap: 0.7rem;
            margin-bottom: 1.4rem;
        }

        .brand__tile {
            width: 2.4rem;
            height: 2.4rem;
            border-radius: 0.7rem;
            background: #fff;
            display: grid;
            place-items: center;
            box-shadow: 0 8px 24px rgba(30, 27, 75, 0.45);
        }

        .brand__wordmark {
            font-weight: 600;
            font-size: 1.6rem;
            letter-spacing: -0.025em;
            color: #fff;
        }

        .brand__tag {
            font-size: 1.05rem;
            line-height: 1.55;
            color: #c7d2fe;
            margin: 0;
        }

        /* ---- Form panel ---------------------------------------------------- */
        .auth__panel {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2.5rem 1.5rem;
            background: var(--surface);
        }

        .auth__card { width: 100%; max-width: 22rem; }

        .form__head { margin-bottom: 1.9rem; }

        .form__title {
            font-weight: 600;
            font-size: 1.6rem;
            letter-spacing: -0.025em;
            margin: 0 0 0.35rem;
        }

        .form__sub { color: var(--muted); font-size: 0.92rem; margin: 0; }

        .field { margin-bottom: 1.05rem; }

        .field__label {
            display: block;
            font-size: 0.78rem;
            font-weight: 600;
            letter-spacing: 0.01em;
            color: #334155;
            margin-bottom: 0.4rem;
        }

        .field__input {
            width: 100%;
            font: inherit;
            font-size: 0.95rem;
            color: var(--ink);
            padding: 0.7rem 0.85rem;
            background: var(--surface-2);
            border: 1px solid var(--line);
            border-radius: 0.6rem;
            transition: border-color 0.15s, box-shadow 0.15s, background 0.15s;
        }

        .field__input::placeholder { color: #94a3b8; }

        .field__input:focus {
            outline: none;
            background: #fff;
            border-color: var(--focus);
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.18);
        }

        .form__row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin: 0.4rem 0 1.4rem;
        }

        .remember {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.86rem;
            color: #475569;
            cursor: pointer;
            user-select: none;
        }

        .remember input {
            width: 1rem;
            height: 1rem;
            accent-color: var(--indigo-600);
            cursor: pointer;
        }

        .btn {
            width: 100%;
            font: inherit;
            font-weight: 600;
            font-size: 0.95rem;
            color: #fff;
            padding: 0.75rem 1rem;
            border: 0;
            border-radius: 0.6rem;
            cursor: pointer;
            background: linear-gradient(180deg, var(--indigo-600), var(--indigo-700));
            box-shadow: 0 6px 16px rgba(79, 70, 229, 0.28);
            transition: transform 0.12s, box-shadow 0.15s, filter 0.15s;
        }

        .btn:hover { filter: brightness(1.06); box-shadow: 0 8px 22px rgba(79, 70, 229, 0.34); }
        .btn:active { transform: translateY(1px); }
        .btn:focus-visible { outline: 3px solid rgba(99, 102, 241, 0.5); outline-offset: 2px; }

        .errors {
            margin-bottom: 1.25rem;
            padding: 0.7rem 0.85rem;
            font-size: 0.85rem;
            color: #b91c1c;
            background: #fef2f2;
            border: 1px solid #fecaca;
            border-radius: 0.55rem;
        }
        /* ASP.NET's validation summary renders an (empty) <ul> even when the form
           is valid, so `:empty` alone won't hide it — key off the framework's
           validation-summary-valid class it adds when there are no errors. */
        .errors:empty,
        .errors.validation-summary-valid { display: none; }
        .errors ul { margin: 0; padding: 0; list-style: none; }
        .errors li { margin: 0; }

        .form__foot {
            margin-top: 2.5rem;
            font-size: 0.75rem;
            color: #94a3b8;
        }

        /* ---- Responsive ---------------------------------------------------- */
        @@media (max-width: 860px) {
            .auth { grid-template-columns: 1fr; }
            .auth__brand {
                padding: 2rem 1.5rem 1.75rem;
                min-height: auto;
            }
            .brand__grid { display: none; }
            .brand__content { max-width: none; }
            .brand__tag { display: none; }
            .brand__mark { margin-bottom: 0; }
        }

        /* ---- Motion: a school day being scheduled -------------------------- */
        @@media (prefers-reduced-motion: no-preference) {
            .auth__panel { animation: rise 0.5s cubic-bezier(0.22, 1, 0.36, 1) both; }
            .brand__content { animation: rise 0.6s cubic-bezier(0.22, 1, 0.36, 1) 0.05s both; }
            .cell--lesson { animation: pop 0.45s cubic-bezier(0.34, 1.56, 0.64, 1) both; animation-delay: var(--d, 0ms); }

            @@keyframes rise { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: none; } }
            @@keyframes pop { from { opacity: 0; transform: scale(0.82); } to { opacity: 1; transform: none; } }
        }
    </style>
</head>
<body>
<div class="auth">
    <aside class="auth__brand">
        <div class="brand__grid" aria-hidden="true">
            @{
                var records = new Dictionary<int, string>
                {
                    { 2, "a" }, { 6, "c" }, { 9, "b" }, { 13, "d" }, { 16, "a" }, { 22, "c" }, { 24, "b" }
                };
            }
            @for (var i = 0; i < 30; i++)
            {
                var isRecord = records.TryGetValue(i, out var kind);
                <div class="cell @(isRecord ? "cell--lesson cell--" + kind : "")" style="@(isRecord ? $"--d:{i * 25}ms" : "")"></div>
            }
        </div>

        <div class="brand__content">
            <div class="brand__mark">
                <span class="brand__tile" aria-hidden="true">
                    <svg width="22" height="20" viewBox="0 0 576 512" xmlns="http://www.w3.org/2000/svg">
                        <path fill="#4f46e5" d="M48 195.8l209.2 86.1c9.8 4 20.2 6.1 30.8 6.1s21-2.1 30.8-6.1l242.4-99.8c9-3.7 14.8-12.4 14.8-22.1s-5.8-18.4-14.8-22.1L318.8 38.1C309 34.1 298.6 32 288 32s-21 2.1-30.8 6.1L14.8 137.9C5.8 141.6 0 150.3 0 160L0 456c0 13.3 10.7 24 24 24s24-10.7 24-24l0-260.2zm48 71.7L96 384c0 53 86 96 192 96s192-43 192-96l0-116.6-142.9 58.9c-15.6 6.4-32.2 9.7-49.1 9.7s-33.5-3.3-49.1-9.7L96 267.4z" />
                    </svg>
                </span>
                <span class="brand__wordmark">MyPortal</span>
            </div>
            <p class="brand__tag">Your school, all in one place — for staff, students, and families.</p>
        </div>
    </aside>

    <main class="auth__panel">
        <div class="auth__card">
            <div class="form__head">
                <h1 class="form__title">@ViewData["Title"]</h1>
                <p class="form__sub">Sign in to your MyPortal account.</p>
            </div>

            @RenderBody()

            <p class="form__foot">&copy; @DateTime.UtcNow.Year MyPortal</p>
        </div>
    </main>
</div>

@RenderSection("Scripts", required: false)
</body>
</html>
